    "lint": "eslint .",
    "preview:pages": "pnpm build:pages && wrangler pages dev .vercel/output/static",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "fund:rehearsal": "node scripts/fund-mode-beta-rehearsal.mjs",
