{
  "name": "fundwise",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "description": "FundWise — Group money, done right. Split expenses and settle in stablecoins; pool shared treasuries with proposal-based spending.",
