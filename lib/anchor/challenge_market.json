      "code": 6000,
      "name": "InvalidOutcome",
      "msg": "Invalid outcome index"
    },
    {
      "code": 6001,
      "name": "AlreadySettled",
      "msg": "Challenge already settled"
    },
    {
      "code": 6002,
      "name": "ConsensusNotReached",
      "msg": "Consensus not reached"
    },
    {
      "code": 6003,
