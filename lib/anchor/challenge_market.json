          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "prizePool",
            "type": "u64"
          },
          {
            "name": "outcomes",
            "type": {
              "vec": "string"
            }
          },
          {
            "name": "winnerVotes",
            "type": {
              "vec": "u16"
            }
          },
          {
            "name": "consensusThreshold",
            "type": "u8"
          },
          {
            "name": "bettingEnabled",
            "type": "bool"
          },
          {
            "name": "totalBets",
            "type": "u64"
          },
          {
            "name": "isSettled",
            "type": "bool"
          },
          {
            "name": "createdAt",
            "type": "i64"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    },
    {
      "name": "Bet",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "challenge",
            "type": "publicKey"
          },
          {
            "name": "bettor",
            "type": "publicKey"
          },
          {
            "name": "outcomeIndex",
            "type": "u8"
          },
          {
            "name": "amount",
            "type": "u64"
          },
          {
            "name": "payoutClaimed",
            "type": "bool"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    }
